<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>For Now</title>

<style>
















/* Column header row (From / Subject / Received) */
.colHeader{
  background:#a9a19d !important;
}

/* Header row (From / Subject / Received) */
.listHeader{
  background:#a9a19d !important;
}

/* Beige background for the 'Inbox' header strip and the message subject strip */
.listTop,
.readerTop{
  background:#a9a19d !important;
}

/* Light beige panels for Inbox header and message title area */
.inboxHeader,
.readerHeader,
.readerTitleBar,
.titleBar{
  background-color:#a9a19d !important;
}

/* Match Inbox and Subject header boxes to classic beige */
.inboxHeader,
.readerTitle{
  background-color:#a9a19d !important;
}

/* Classic Windows 2000 header beige */
.headerBar,
.readerHeader{
  background-color:#a9a19d;
}

/* Bold subjects only when unread */
.msg.unread .line1{
  font-weight:700;
}

/* Unopened (unread) email subject in red */
.msg.unread .line1{
  color:#9e2a2a;
}

@font-face{
  font-family:"Aktiv Grotesk";
  src: local("Aktiv Grotesk"), local("AktivGrotesk-Regular");
  font-weight: 400;
}
@font-face{
  font-family:"Aktiv Grotesk";
  src: local("Aktiv Grotesk Medium"), local("AktivGrotesk-Medium");
  font-weight: 500;
}
@font-face{
  font-family:"Aktiv Grotesk";
  src: local("Aktiv Grotesk Bold"), local("AktivGrotesk-Bold");
  font-weight: 700;
}

@keyframes blink{
  0%,100%{opacity:1}
  50%{opacity:0}
}

:root{
  --sel:#b8d4f8;
  --sel-border:#4e88d0;
  --line:#555555;
  --bg:#008080;
  --panel:#ffffff;
  --muted:#222222;
  --text:#000;
  --xp-blue:#061852;
  --xp-blue2:#2a5aaa;
  --menu:#a9a19d;
  --btn:#a9a19d;
  --btn-hi:#ffffff;
  --btn-lo:#808080;
}

*{box-sizing:border-box}
html,body{height:100%}
body{
  margin:0;
  font-family: Tahoma, "MS Sans Serif", Arial, sans-serif;
  background:var(--bg);
  color:var(--text);
}

.app{
  height:calc(100% - 30px);
  display:grid;
  grid-template-rows: 32px 22px 36px 1fr;
}

.titlebar{
  background: linear-gradient(180deg, #2255b8 0%, #123088 40%, #0e2478 100%);
  color:#fff;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 10px;
  font-size:12px;
  height:32px;
}
.titlebar .left{
  display:flex;
  gap:12px;
  align-items:center;
}
.badge{
  width:16px;height:16px;
  background:#ffffff;
  opacity:.9;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  color:var(--blue);
  font-weight:700;
  font-size:11px;
}
.titlebar .right{
  opacity:.95;
}

.menubar{
  background:var(--menu);
  border-bottom:1px solid var(--line);
  display:flex;
  align-items:center;
  gap:12px;
  padding:2px 8px;
  height:22px;
  font-size:12px;
}
.menuItem{
  padding:2px 6px;
  cursor:default;
  user-select:none;
}
.menuItem:hover{
  background:#ffffff;
  border:1px solid var(--line);
  padding:1px 5px;
}

.toolbar{
  background:var(--menu);
  border-bottom:1px solid var(--line);
  display:flex;
  align-items:center;
  gap:6px;
  padding:4px 12px 4px 6px;
  height:34px;
}
.tbtn{
  display:flex;
  align-items:center;
  gap:6px;
  padding:3px 8px;
  border-top:1px solid var(--btn-hi);
  border-left:1px solid var(--btn-hi);
  border-right:1px solid var(--btn-lo);
  border-bottom:1px solid var(--btn-lo);
  background:var(--btn);
  font-size:12px;
  cursor:pointer;
}
.tbtn:active{
  border-top:1px solid var(--btn-lo);
  border-left:1px solid var(--btn-lo);
  border-right:1px solid var(--btn-hi);
  border-bottom:1px solid var(--btn-hi);
}
.tico{
  width:16px;height:16px;
  background:linear-gradient(#fff,#cfcfcf);
  border:1px solid #666;
}
.sep{
  width:1px;
  height:22px;
  background:var(--line);
  margin:0 4px;
}

.main{
  display:grid;
  grid-template-columns: 260px 420px 1fr;
  height:100%;
  min-height:0;
}
.panel{
  background:var(--panel);
  border-right:1px solid var(--line);
  min-height:0;
}
.panel:last-child{border-right:none}

.navTop{
  padding:6px;
  border-bottom:1px solid var(--line);
  background:var(--menu);
}
.search{
  width:100%;
  padding:6px 8px;
  border-top:1px solid #808080;
  border-left:1px solid #808080;
  border-right:1px solid #ffffff;
  border-bottom:1px solid #ffffff;
  font-size:12px;
  outline:none;
  background:#ffffff;
  color:#000;
}
.search::placeholder{ color:#444444; opacity:1; }
.search::-webkit-input-placeholder{ color:#444444; }
.search::-moz-placeholder{ color:#444444; }
input::placeholder{ color:#444444; opacity:1; }
input::-webkit-input-placeholder{ color:#444444; }
input::-moz-placeholder{ color:#444444; }
.section{
  padding:10px 10px 6px 10px;
  font-size:12px;
  font-weight:600;
  letter-spacing:.03em;
  color:#333;
  text-transform:uppercase;
}
.folders{padding:0 0 12px 0}
.folder{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:8px 10px;
  font-size:14px;
  cursor:pointer;
}
.folder:hover{background:#9e9693}
.folder.has-new-mail .folder-name{color:#9e2a2a;font-weight:700;}
.folder.has-new-mail .count{color:#9e2a2a;font-weight:700;}
.folder.active{
  background:var(--sel);
  color:#222;
  font-weight:600;

.folder.active .count{color:#222;opacity:.85;}
}
.count{
  font-size:12px;
  opacity:.85;
}

.listTop{
  padding:10px 12px;
  border-bottom:1px solid var(--line);
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:#ffffff;
}
.listTitle{
  font-size:22px;
  font-weight:700;
}
.listTools{
  font-size:12px;
  color:var(--muted);
  user-select:none;
}
.colHeader{
  display:grid;
  grid-template-columns: 140px 1fr 80px;
  gap:10px;
  padding:6px 10px;
  font-size:12px;
  background:var(--menu);
  border-bottom:1px solid var(--line);
  color:#000;
}
.messages{
  overflow-x:hidden;
  min-height:0;
  overflow:auto;
}
.from{font-size:12px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; padding-top:2px;}

.msg{
  display:grid;
  grid-template-columns: 140px 1fr 80px;
  gap:10px;
  padding:8px 10px;
  border-bottom:1px solid #888888;
  cursor:pointer;
  background:#ffffff;
}
@keyframes msgSlideDown {
  0%   { opacity:0; transform: translateY(-18px); max-height:0; }
  40%  { opacity:1; }
  100% { opacity:1; transform: translateY(0);     max-height:60px; }
}
.msg-new {
  animation: msgSlideDown 0.38s cubic-bezier(0.22,0.61,0.36,1) both;
}
.msg:hover{background:#9e9693}
.msg.selected{
  background:var(--sel);
  color:#222;
}
.line1{
  font-size:13px;
  font-weight:400;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}
.line2{
  font-size:13px;
  color:var(--muted);
  margin-top:4px;
  white-space:nowrap;
  overflow:hidden;
  text-overflow:ellipsis;
}
.msg.selected .line2{color:#444}
.time{
  width:80px;
  white-space:nowrap;
  text-align:right;
  overflow:hidden;
  font-size:12px;
  color:var(--muted);
  text-align:right;
  padding-top:2px;
}
.msg.selected .time{
  width:80px;
  white-space:nowrap;
  text-align:right;
  overflow:hidden;color:#444}

.readerTop{
  padding:10px 12px;
  border-bottom:1px solid var(--line);
  background:#ffffff;
}
.subject{
  font-size:20px;
  font-weight:500;
  margin:0;
}
.meta{
  margin-top:6px;
  font-size:12px;
  color:var(--muted);
}
.readerBody{
  padding:16px 14px 70px 14px;
  min-height:0;
  overflow:auto;
  background:#ffffff;
  font-size:14px;
  line-height:1.55;
}

/* Early-2000s Windows textbox styling for editable draft prompts */
.editor{
  margin-top:8px;
  min-height:260px;
  padding:10px 10px;
  background:#ffffff;
  color:#000;
  font-family: Tahoma, "MS Sans Serif", Arial, sans-serif;
  font-size:13px;
  line-height:1.4;
  white-space:pre-wrap;

  /* classic inset 3D border */
  border-top:1px solid #808080;
  border-left:1px solid #808080;
  border-right:1px solid #ffffff;
  border-bottom:1px solid #ffffff;

  /* inner groove */
  box-shadow: inset 1px 1px 0 #404040, inset -1px -1px 0 #a9a19d;
}
.editor:focus{
  outline:1px dotted #000;
  outline-offset:-3px;
}

.saveRow{
  position:sticky;
  bottom:0;
  background:#ffffff;
  
  padding:10px 14px;
  display:flex;
  justify-content:flex-end;
}
.saveBtn{
  background:var(--btn);
  border-top:1px solid var(--btn-hi);
  border-left:1px solid var(--btn-hi);
  border-right:1px solid var(--btn-lo);
  border-bottom:1px solid var(--btn-lo);
  padding:6px 12px;
  font-size:12px;
  cursor:pointer;
}
.saveBtn:active{
  border-top:1px solid var(--btn-lo);
  border-left:1px solid var(--btn-lo);
  border-right:1px solid var(--btn-hi);
  border-bottom:1px solid var(--btn-hi);
}

.p{margin:0 0 10px 0;}

/* Prevent horizontal scroll in list views */
.listPanel, .messages{
  overflow-x:hidden !important;
}
.msg{
  max-width:100%;
}
/* Make the middle column clip rather than expand */
.msg > div:nth-child(2){
  overflow:hidden;
  min-width:0;
}
.line1, .line2{
  overflow:hidden;
  text-overflow:ellipsis;
  white-space:nowrap;
  max-width:100%;
}


.btnRow{
  display:flex;
  gap:8px;
  align-items:center;
  justify-content:flex-end;
}


/* Outlook 2000s-style status bar */
.statusbar{
  height:22px;
  background:var(--menu);
  border-top:1px solid #808080;
  display:flex;
  align-items:stretch;
  gap:0;
}
.sbPane{
  flex:1;
  display:flex;
  align-items:center;
  padding:0 8px;
  font-size:12px;
  color:#000;
  border-left:1px solid #ffffff;
  border-top:1px solid #ffffff;
  border-right:1px solid #808080;
  border-bottom:1px solid #808080;
  min-width:0;
}
.sbMid{
  flex:0 0 180px;
  justify-content:center;
}
.sbRight{
  flex:0 0 110px;
  justify-content:flex-end;
}


/* Classic 2000s dialog */
.modalOverlay{
  position:fixed;
  inset:0;
  background:rgba(0,0,0,.25);
  display:flex;
  align-items:center;
  justify-content:center;
  z-index:9999;
}
.modalWin{
  width:360px;
  background:#a9a19d;
  border-top:1px solid #ffffff;
  border-left:1px solid #ffffff;
  border-right:1px solid #404040;
  border-bottom:1px solid #404040;
  box-shadow: 3px 3px 0 rgba(0,0,0,.4);
  font-family: Tahoma, "MS Sans Serif", Arial, sans-serif;
}
.modalTitlebar{
  height:26px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:0 6px;
  background: linear-gradient(180deg, #2a5a8f, #142d5c);
  color:#fff;
  font-size:12px;
  font-weight:600;
}
.modalClose{
  width:18px;
  height:18px;
  display:flex;
  align-items:center;
  justify-content:center;
  background:#a9a19d;
  color:#000;
  border-top:1px solid #fff;
  border-left:1px solid #fff;
  border-right:1px solid #808080;
  border-bottom:1px solid #808080;
  cursor:pointer;
  user-select:none;
  line-height:1;
}
.modalClose:active{
  border-top:1px solid #808080;
  border-left:1px solid #808080;
  border-right:1px solid #fff;
  border-bottom:1px solid #fff;
}
.modalBody{
  display:flex;
  gap:14px;
  padding:16px 14px;
  background:#a9a19d;
  font-size:12px;
  align-items:center; /* vertical alignment with icon */
}
.modalIcon{
  width:32px;
  height:32px;
  background: radial-gradient(circle at 30% 30%, #cc2222, #8b0000);
  border-radius:50%;
  position:relative;
  box-shadow: inset 0 0 0 2px #5a0000;
}
.modalIcon::before,
.modalIcon::after{
  content:"";
  position:absolute;
  top:5px;
  left:14px;
  width:4px;
  height:22px;
  background:#ffffff;
}
.modalIcon::before{
  transform:rotate(45deg);
}
.modalIcon::after{
  transform:rotate(-45deg);
}
.modalIcon::before,
.modalIcon::after{
  content:"";
  position:absolute;
  top:6px;
  left:15px;
  width:2px;
  height:20px;
  background:#ffffff;
}
.modalIcon::before{
  transform:rotate(45deg);
}
.modalIcon::after{
  transform:rotate(-45deg);
}
.modalMsg{
  font-size:12px;
  color:#000;
  line-height:1.25;
}
.modalBtns{
  display:flex;
  justify-content:flex-end;
  padding:0 10px 10px 10px;
}
.modalBtn{
  min-width:75px;
  height:24px;
  background:#a9a19d;
  border-top:1px solid #ffffff;
  border-left:1px solid #ffffff;
  border-right:1px solid #808080;
  border-bottom:1px solid #808080;
  font-size:12px;
  cursor:pointer;
}
.modalBtn:active{
  border-top:1px solid #808080;
  border-left:1px solid #808080;
  border-right:1px solid #ffffff;
  border-bottom:1px solid #ffffff;
}
.modalBtn:active{
  border-top:1px solid var(--btn-lo);
  border-left:1px solid var(--btn-lo);
  border-right:1px solid var(--btn-hi);
  border-bottom:1px solid var(--btn-hi);
}


/* Early-2000s style shutdown overlay */
.shutdownOverlay{
  position:fixed;
  inset:0;
  background: linear-gradient(180deg, #143d90 0%, #0e2e72 30%, #081e52 65%, #050f38 100%);
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  z-index:10000;
  font-family: Tahoma, "MS Sans Serif", Arial, sans-serif;
}
.shutdownLogo{
  display:flex;
  align-items:center;
  gap:0;
  margin-bottom:20px;
}
.shutdownLogoFlag{
  display:grid;
  grid-template-columns:1fr 1fr;
  grid-template-rows:1fr 1fr;
  width:48px;
  height:48px;
  gap:3px;
  margin-right:12px;
  border-radius:3px;
  overflow:hidden;
  box-shadow:0 2px 8px rgba(0,0,0,0.5);
}
.shutdownLogoFlag span:nth-child(1){ background:linear-gradient(135deg,#ff6a3d,#f25022,#c73a10); }
.shutdownLogoFlag span:nth-child(2){ background:linear-gradient(135deg,#88bb00,#669900,#446600); }
.shutdownLogoFlag span:nth-child(3){ background:linear-gradient(135deg,#6666ff,#3333ff,#1a1acc); }
.shutdownLogoFlag span:nth-child(4){ background:linear-gradient(135deg,#ffbb33,#cc9900,#996600); }
.shutdownLogoText{
  font-size:36px;
  font-weight:300;
  color:#fff;
  letter-spacing:2px;
  text-shadow:1px 2px 6px rgba(0,0,0,0.5);
}
.shutdownLogoText b{ font-weight:700; }
.shutdownInner{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:14px;
}
.shutdownText{
  font-size:14px;
  color:#a0c8f0;
  letter-spacing:.5px;
  text-align:center;
  font-style:italic;
}
.shutdownDots{
  display:flex;
  gap:6px;
  align-items:center;
}
.shutdownDots span{
  width:8px;
  height:8px;
  border-radius:50%;
  background:#4a9cd8;
  animation: dotPulse 1.4s ease-in-out infinite;
}
.shutdownDots span:nth-child(2){ animation-delay:.2s; }
.shutdownDots span:nth-child(3){ animation-delay:.4s; }
.shutdownDots span:nth-child(4){ animation-delay:.6s; }
.shutdownDots span:nth-child(5){ animation-delay:.8s; }
@keyframes dotPulse{
  0%,80%,100%{ opacity:.2; transform:scale(0.85); }
  40%{ opacity:1; transform:scale(1.15); }
}
@keyframes spin{
  to{ transform: rotate(360deg); }
}
.shutdownSafeMsg{
  display:none;
  font-size:14px;
  color:#2882d0;
  letter-spacing:.5px;
  margin-top:8px;
  text-align:center;
}
.shutdownBar{
  width:200px;
  height:14px;
  border:1px solid #555;
  background:#111;
  margin-top:4px;
  overflow:hidden;
  display:none;
}
.shutdownBarFill{
  height:100%;
  width:0%;
  background:linear-gradient(90deg,#0d52a0,#2882d0);
  transition:width 0.4s linear;
}


/* tiny envelope icon in title bar */
.envIcon{
  width:12px;
  height:9px;
  display:inline-block;
  margin-right:6px;
  position:relative;
  top:1px;
  border:1px solid rgba(255,255,255,.95);
  box-sizing:border-box;
}
.envIcon:before{
  content:"";
  position:absolute;
  left:0;
  top:0;
  width:100%;
  height:100%;
  background:transparent;
  clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%);
}
.envIcon:after{
  content:"";
  position:absolute;
  left:1px;
  top:1px;
  right:1px;
  bottom:1px;
  background:
    linear-gradient(135deg, transparent 48%, rgba(255,255,255,.95) 49%, rgba(255,255,255,.95) 51%, transparent 52%),
    linear-gradient(225deg, transparent 48%, rgba(255,255,255,.95) 49%, rgba(255,255,255,.95) 51%, transparent 52%);
  opacity:.95;
}
.titleText{ vertical-align:middle; }


