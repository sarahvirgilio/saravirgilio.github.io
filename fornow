    renderMessages();
    updateNewMailIndicator();
}, delay);
}


function canRevealAfterOpen(currentId){
  // For editable prompts, reveal next only after the user clicks Save/Send/Delete
  if(currentId === "m1" || currentId === "m7") return false;
  const nextId = nextById[currentId];
  if(!nextId) return false;
  const nextMsg = messages.find(m=>m.id===nextId);
  if(!nextMsg) return false;
  if(nextMsg.visible) return false;
return true;
}

function scheduleRevealNextAfterOpen(currentId){
  const nextId = nextById[currentId];
  if(!nextId) return;

  // prevent multiple timers stacking
  if(revealTimer){
    clearTimeout(revealTimer);
    revealTimer = null;
  }

  if(!canRevealAfterOpen(currentId)) return;
  if(revealedOnce.has(currentId)) return; // only once per message-open

  const delay = 3000 + Math.random() * 3000;
  revealTimer = setTimeout(()=>{
    const nextMsg = messages.find(m=>m.id===nextId);
    if(!nextMsg || nextMsg.visible) return;
    revealedOnce.add(currentId); // mark only after timer fires
    nextMsg.visible = true;
    nextMsg.unread = true;
    nextMsg.revealedAt = Date.now();
    nextMsg.shownTime = "Now";
    newlyRevealedIds.add(nextMsg.id);
    playSound("newmail");
    renderFolders();
    renderMessages();
    updateNewMailIndicator();
  }, delay);
}


