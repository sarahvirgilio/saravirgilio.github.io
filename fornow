// --- Persistent Archive (Drafts/Sent/Trash) ---
const ARCHIVE_KEY = "mailPrototypeArchive_v1";
const ARCHIVE_ALL_KEY = "mailPrototypeArchive_all";

// Get a session ID that increments each time the page loads
function getSessionId(){
  try{
    let sid = parseInt(sessionStorage.getItem("forNowSession")||"0");
    if(!sid){
      sid = (parseInt(localStorage.getItem("forNowSessionCounter")||"0")) + 1;
      localStorage.setItem("forNowSessionCounter", sid);
      sessionStorage.setItem("forNowSession", sid);
    }
    return sid;
  }catch(e){ return 1; }
}
const SESSION_ID = getSessionId();
const SESSION_START = new Date().toISOString();

function getArchiveMessages(){
  return messages.filter(m=>m && m.visible && (m.folder==="drafts" || m.folder==="sent" || m.folder==="trash"));
}

function saveArchive(){
  try{
    // Save current session snapshot (existing behaviour)
    localStorage.setItem(ARCHIVE_KEY, JSON.stringify(getArchiveMessages()));

    // Also accumulate into the all-sessions archive
    const allRaw = localStorage.getItem(ARCHIVE_ALL_KEY);
    const all = allRaw ? JSON.parse(allRaw) : [];

    getArchiveMessages().forEach(m=>{
      // Avoid duplicates — key by id + session
      const key = `${SESSION_ID}::${m.id}`;
      const exists = all.find(e=>e._key===key);
      const entry = {
        _key: key,
        session: SESSION_ID,
        sessionStart: SESSION_START,
        savedAt: new Date().toISOString(),
        folder: m.folder,
        subject: m.subject || "",
        response: (m.answer || (Array.isArray(m.body) ? m.body.join(" ") : "")).trim()
      };
      if(exists){
        Object.assign(exists, entry);
      } else {
        all.push(entry);
      }
    });
    localStorage.setItem(ARCHIVE_ALL_KEY, JSON.stringify(all));
  }catch(e){}
}

function loadArchive(){
  try{
    const raw = localStorage.getItem(ARCHIVE_KEY);
    if(!raw) return;
    const arr = JSON.parse(raw);
    if(!Array.isArray(arr)) return;
    arr.forEach(a=>{
      if(!a || !a.id) return;
      if(messages.find(m=>m.id===a.id)) return;
      a.visible = true;
      a.unread = false;
      messages.push(a);
    });
  }catch(e){}
}

function exportArchive(){
  try{
    const allRaw = localStorage.getItem(ARCHIVE_ALL_KEY);
    const all = allRaw ? JSON.parse(allRaw) : [];
    if(!all.length){
      alert("No archive entries yet.");
      return;
    }

    // Group by session
    const sessions = {};
    all.forEach(e=>{
      const s = e.session || "?";
      if(!sessions[s]) sessions[s] = { start: e.sessionStart, entries: [] };
      sessions[s].entries.push(e);
    });

    let txt = "FOR NOW — GALLERY ARCHIVE\n";
    txt += "Exported: " + new Date().toLocaleString() + "\n";
    txt += "Total responses: " + all.length + "\n";
    txt += "=".repeat(50) + "\n\n";

    Object.keys(sessions).sort((a,b)=>a-b).forEach(sid=>{
      const s = sessions[sid];
      txt += `SESSION ${sid}`;
      if(s.start) txt += `  (${new Date(s.start).toLocaleString()})`;
      txt += "\n" + "-".repeat(40) + "\n";
      s.entries.forEach(e=>{
        txt += `Prompt:   ${e.subject}\n`;
        txt += `Action:   ${e.folder}\n`;
        txt += `Response: ${e.response || "(none)"}\n`;
        txt += `Saved:    ${e.savedAt ? new Date(e.savedAt).toLocaleString() : "unknown"}\n\n`;
      });
      txt += "\n";
    });

    const blob = new Blob([txt], {type:"text/plain"});
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "ForNow_Archive_" + new Date().toISOString().slice(0,10) + ".txt";
    a.click();
    URL.revokeObjectURL(url);
  }catch(e){ alert("Export failed: " + e); }
}

