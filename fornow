let actionRevealOnce = new Set();

function scheduleRevealNextAfterAction(currentId){
  const nextId = nextById[currentId];
  if(!nextId) return;

  if(actionRevealOnce.has(currentId)) return;
  actionRevealOnce.add(currentId);

  const delay = 3000 + Math.random() * 3000;
  setTimeout(()=>{
    const nextMsg = messages.find(m=>m.id===nextId);
    if(!nextMsg || nextMsg.visible) return;
    nextMsg.visible = true;
    nextMsg.unread = true;
    nextMsg.revealedAt = Date.now();
    nextMsg.shownTime = "Now";
    newlyRevealedIds.add(nextMsg.id);
