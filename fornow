            font-size:26px;
            transition:filter 0.1s;
          " onmouseover="this.style.filter='brightness(1.2)'" onmouseout="this.style.filter=''">🌙</div>
          <span style="font-size:11px;color:#00318a;font-weight:bold;">Stand By</span>
        </div>

        <!-- Turn Off -->
        <div onclick="document.getElementById('xpTurnOffDialog').style.display='none';" style="cursor:default;display:flex;flex-direction:column;align-items:center;gap:6px;width:82px;">
          <div style="
            width:64px;height:64px;
            background:linear-gradient(180deg,#2e5cba,#0e2e72);
            border-radius:50%;
            border:2px solid #8ab0f0;
            box-shadow:0 3px 8px rgba(0,0,0,0.4),inset 0 2px 0 rgba(255,255,255,0.2);
            display:flex;align-items:center;justify-content:center;
            font-size:26px;
            transition:filter 0.1s;
          " onmouseover="this.style.filter='brightness(1.2)'" onmouseout="this.style.filter=''">🔴</div>
          <span style="font-size:11px;color:#00318a;font-weight:bold;">Turn Off</span>
        </div>

        <!-- Restart -->
        <div onclick="document.getElementById('xpTurnOffDialog').style.display='none';" style="cursor:default;display:flex;flex-direction:column;align-items:center;gap:6px;width:82px;">
          <div style="
            width:64px;height:64px;
            background:linear-gradient(180deg,#2e5cba,#0e2e72);
            border-radius:50%;
            border:2px solid #8ab0f0;
            box-shadow:0 3px 8px rgba(0,0,0,0.4),inset 0 2px 0 rgba(255,255,255,0.2);
