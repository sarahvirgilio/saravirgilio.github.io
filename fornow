        </div>

      </div>

      <!-- Cancel button -->
      <div style="margin-top:18px;">
        <button onclick="document.getElementById('xpTurnOffDialog').style.display='none';" style="
          padding:4px 22px;
          background:linear-gradient(180deg,#f0f0f0,#d8d8d8);
          border:1px solid #888;
          border-radius:3px;
          font-family:Tahoma,sans-serif;
          font-size:11px;
