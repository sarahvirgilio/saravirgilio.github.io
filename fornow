function resetToHomeScreen(){
  try{ if(actionRevealOnce && actionRevealOnce.clear) actionRevealOnce.clear(); }catch(e){}
  // Hide any overlays that might be up
  const ov1 = document.getElementById("modalOverlay");
  const ov2 = document.getElementById("modalOverlay2");
  if(ov1) ov1.style.display = "none";
  if(ov2) ov2.style.display = "none";

  // Hide shutdown overlay and restore its default text
  const shut = document.getElementById("shutdownOverlay");
  const shutText = document.getElementById("shutdownText");
  const shutDots = document.getElementById("shutdownDots");
  const shutBar = document.getElementById("shutdownBar");
  const shutFill = document.getElementById("shutdownBarFill");
  const shutSafe = document.getElementById("shutdownSafeMsg");
  if(shutText){ shutText.textContent = "Please take a look around"; shutText.style.display = ""; }
  if(shutDots) shutDots.style.display = "";
  if(shutBar) shutBar.style.display = "none";
  if(shutFill) shutFill.style.width = "0%";
  if(shutSafe) shutSafe.style.display = "none";
  if(shut) shut.style.display = "none";

  // Reset progression state and message visibility to the initial "home screen"
  try{
    if(typeof revealedOnce !== "undefined" && revealedOnce && revealedOnce.clear) revealedOnce.clear();
  }catch(e){}
  try{ if(typeof firstDraftCompleted !== "undefined") firstDraftCompleted = false; }catch(e){}
  try{ if(typeof secondDraftCompleted !== "undefined") secondDraftCompleted = false; }catch(e){}
  try{ if(typeof endSequenceStarted !== "undefined") endSequenceStarted = false; }catch(e){}
  try{ if(typeof revealTimer !== "undefined" && revealTimer){ clearTimeout(revealTimer); revealTimer = null; } }catch(e){}

  // Reset per-message flags
  try{
    messages.forEach(m=>{
      // Keep archive folders intact across resets
      if(m.folder === "drafts" || m.folder === "sent" || m.folder === "trash"){
        return;
      }
      m.actionTaken = false;
      m.acknowledged = false;
      m.visible = false;
      m.unread = false;
      m.sent = false;
      m.deleted = false;
      if(m.editable){
        m.answer = "";
        m.body = [""];
      }
      m.revealedAt = Date.now();
      m.shownTime = "Now";
    });
  }catch(e){}

  // Reset UI state
  try{
    state.folder = "inbox";
    state.selected = null;
    state.query = "";
    state.timelineStarted = false;
  }catch(e){}

  // Clear search input field
  try{
    const si = document.getElementById("searchInput");
    if(si) si.value = "";
  }catch(e){}

  renderAll();
  clearReader();

  // Return to the "Please Take a Seat" login screen
  try{
    var loginEl2 = document.getElementById("xpLogin");
    var appEl2   = document.getElementById("appMain");
    var taskbar  = document.getElementById("xpTaskbar");
    if(loginEl2) loginEl2.style.display = "";
    if(appEl2)   appEl2.style.opacity   = "0";
    if(taskbar)  taskbar.style.display  = "none";
    // Re-arm the login click handler
    if(typeof window._rearmLogin === "function") window._rearmLogin();
  }catch(e){}


}

// --- Inactivity countdown overlay ---
(function(){
  const IDLE_MS = 120000;   // 2 minutes before warning
  const COUNT_S = 10;       // 10 second countdown

  let idleTimer = null;
  let countTimer = null;
  let counting = false;

  // Build the warning overlay (XP dialog style)
  const warn = document.createElement("div");
  warn.id = "inactivityWarn";
  warn.style.cssText = [
    "display:none","position:fixed","inset:0","z-index:99999",
    "background:rgba(0,0,0,0.55)","align-items:center","justify-content:center"
  ].join(";");
  warn.innerHTML = `
    <div style="background:#d4d0c8;border-top:2px solid #fff;border-left:2px solid #fff;
      border-right:2px solid #808080;border-bottom:2px solid #808080;
      width:340px;font-family:Tahoma,sans-serif;font-size:12px;color:#000;">
      <div style="background:linear-gradient(90deg,#0a246a,#a6b5e3);padding:4px 8px;
        display:flex;justify-content:space-between;align-items:center;">
        <span style="color:#fff;font-weight:bold;font-size:12px;">Session Timeout</span>
      </div>
      <div style="padding:16px 14px 10px;display:flex;gap:12px;align-items:flex-start;">
        <div style="font-size:32px;line-height:1;">⚠️</div>
        <div>
          <div style="margin-bottom:8px;">This session will reset in <b id="warnCount">10</b> seconds.</div>
          <div style="color:#444;">Move the mouse or press any key to return to the start screen now.</div>
        </div>
      </div>
      <div style="padding:0 14px 14px;text-align:right;">
        <button id="warnStayBtn" style="padding:3px 18px;font-family:Tahoma,sans-serif;font-size:12px;
          background:#d4d0c8;border-top:1px solid #fff;border-left:1px solid #fff;
          border-right:1px solid #808080;border-bottom:1px solid #808080;cursor:pointer;">
          Return to Start
        </button>
      </div>
    </div>`;
  document.body.appendChild(warn);

  function doReset(){
    stopCountdown();
    warn.style.display = "none";
    resetToHomeScreen();
    startIdleTimer();
  }

  function stopCountdown(){
    counting = false;
    if(countTimer){ clearInterval(countTimer); countTimer = null; }
  }

  function startCountdown(){
    if(counting) return;
    // Don't show warning if already on the login/home screen
    const loginEl = document.getElementById("xpLogin");
    if(loginEl && loginEl.style.display !== "none"){
      startIdleTimer();
      return;
    }
    counting = true;
    warn.style.display = "flex";
    playSound("error");
    let n = COUNT_S;
    const el = document.getElementById("warnCount");
    if(el) el.textContent = n;
    countTimer = setInterval(()=>{
      n--;
      if(el) el.textContent = n;
      if(n <= 0){ doReset(); }
    }, 1000);
  }

  function startIdleTimer(){
    if(idleTimer) clearTimeout(idleTimer);
    idleTimer = setTimeout(startCountdown, IDLE_MS);
  }

  // Any activity: if countdown showing → go to login immediately; else reset idle timer
  function onActivity(){
    if(counting){
      doReset();
    } else {
      startIdleTimer();
    }
  }

  document.getElementById("warnStayBtn").addEventListener("click", doReset);

  ["mousemove","mousedown","keydown","wheel"].forEach(evt=>{
    document.addEventListener(evt, onActivity, true);
  });

  startIdleTimer();
  window.resetInactivityTimer = startIdleTimer;
})();




// --- Admin: Permanent delete of a single archived email (Shift + Delete) ---
// Works only for Drafts / Sent / Trash items. Updates localStorage archive immediately.
function permanentlyDeleteSelected(){
  try{
    const id = (typeof state !== "undefined" && state) ? state.selected : null;
    if(!id) return;

    const idx = messages.findIndex(m=>m && m.id === id);
    if(idx === -1) return;

    const msg = messages[idx];
    if(!(msg.folder === "drafts" || msg.folder === "sent" || msg.folder === "trash")) return;

    // Remove from in-memory list
    messages.splice(idx, 1);

    // Clear reader selection
    try{
      state.selected = null;
    }catch(e){}

    clearReader();
    renderFolders();
    renderMessages();

    // Persist archive change
    try{ saveArchive(); }catch(e){}
  }catch(e){}
}

// Shift + Delete triggers permanent delete, but not while typing in the editor.
document.addEventListener("keydown", (e)=>{
  if(!e) return;

  const isDeleteKey =
    (e.key === "Delete" || e.key === "Backspace") ||
    (typeof e.keyCode === "number" && (e.keyCode === 46 || e.keyCode === 8));

  if(!(isDeleteKey && e.shiftKey)) return;

  const active = document.activeElement;
  // Don't hijack Shift+Delete inside contenteditable (the response editor)
  if(active && active.isContentEditable) return;

  e.preventDefault();
  permanentlyDeleteSelected();
}, true);

// ===== XP LOGIN SCREEN =====
(function(){
  const loginEl  = document.getElementById("xpLogin");
  const wipeEl   = document.getElementById("xpLoginWipe");
  const appEl    = document.getElementById("appMain");
  const userBox  = document.getElementById("xpUserBox");
  const clockEl  = document.getElementById("xpClockTime");
  const dateEl   = document.getElementById("xpClockDate");
  if(!loginEl || !appEl) return;

  // Live clock on login screen
  function updateXpClock(){
    const now = new Date();
    let h = now.getHours(), m = now.getMinutes();
    const ampm = h >= 12 ? "PM" : "AM";
    h = h % 12 || 12;
    if(clockEl) clockEl.textContent = h + ":" + String(m).padStart(2,"0") + " " + ampm;
    if(dateEl){
      const days = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];
      const months = ["January","February","March","April","May","June","July","August","September","October","November","December"];
      dateEl.textContent = days[now.getDay()] + ", " + months[now.getMonth()] + " " + String(now.getDate()).padStart(2,"0") + ", " + now.getFullYear();
    }
  }
  updateXpClock();
  const xpClockInterval = setInterval(updateXpClock, 1000);

  let triggered = false;
  function doLogin(){
    if(triggered) return;
    triggered = true;
    clearInterval(xpClockInterval);
    playSound("startup");

    const welcomeEl   = document.getElementById("xpWelcome");
    const welcomeText = document.getElementById("welcomeText");
    const welcomeDots = document.getElementById("welcomeDots");

    // Step 1: Fade login screen to black (chunky stepped, ~0.8s)
    wipeEl.style.pointerEvents = "all";
    wipeEl.style.opacity = "1";

    setTimeout(()=>{
      // Step 2: Hide login, show Welcome screen
      loginEl.style.display = "none";
      wipeEl.style.opacity = "0";
      if(welcomeEl) welcomeEl.style.display = "flex";

      // Step 3: Animate in "Welcome" text and dots
      setTimeout(()=>{
        if(welcomeText) welcomeText.classList.add("show");
        if(welcomeDots) welcomeDots.classList.add("show");
      }, 200);

      // Step 4: Hold Welcome screen for ~2.5s, then fade out to app
      setTimeout(()=>{
        // Fade welcome to black — slow and stepped
        wipeEl.style.opacity = "1";
        setTimeout(()=>{
          if(welcomeEl) welcomeEl.style.display = "none";
          if(welcomeText) welcomeText.classList.remove("show");
          if(welcomeDots) welcomeDots.classList.remove("show");

          // Show app — reveal is slow and chunky (1.4s stepped)
          appEl.style.opacity = "1";
          appEl.classList.add("xp-entering");
          const taskbar = document.getElementById("xpTaskbar");
          if(taskbar) taskbar.style.display = "flex";

          setTimeout(()=>{
            wipeEl.style.opacity = "0";
            wipeEl.style.pointerEvents = "none";
            appEl.classList.remove("xp-entering");
            resetInactivityTimer();

            // Reveal m1 after 2 seconds, just like any other incoming email
            setTimeout(()=>{
              const m1 = messages.find(m=>m.id==="m1");
              if(m1 && !m1.visible){
                m1.visible = true;
                m1.unread = true;
                m1.revealedAt = Date.now();
                m1.shownTime = "Now";
                newlyRevealedIds.add("m1");
                playSound("newmail");
                renderFolders();
                renderMessages();
                updateNewMailIndicator();
              }
            }, 2000);
          }, 1600);
        }, 900);
      }, 2500);

    }, 900);
  }

  // Re-register login click every time the login screen becomes visible
  window._rearmLogin = function(){
    triggered = false;
    if(userBox){
      userBox.removeEventListener("click", doLogin);
      userBox.addEventListener("click", doLogin);
    }
  };

  // Initial registration
  if(userBox) userBox.addEventListener("click", doLogin);
})();

